<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Hoàng Dũng & Quỳnh Linh - Wedding Invitation</title>
  <link href="https://fonts.googleapis.com/css2?family=Dancing+Script:wght@600;700&family=Montserrat:wght@300;400;500&family=Playfair+Display:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary-color: #9C8262; /* Màu vàng đồng/beige sang trọng */
      --primary-dark: #7A654C;
      --bg-color: #FAF8F5; /* Màu nền trắng kem */
      --text-main: #4A4A4A;
    }
    
    * { margin:0; padding:0; box-sizing:border-box; }
    body { 
      overflow-x:hidden; 
      font-family: 'Montserrat', sans-serif;
      background-color: var(--bg-color);
      color: var(--text-main);
    }

    /* --- Màn hình mở thiệp --- */
    #openCardOverlay {
      position: fixed; top:0; left:0; width:100%; height:100%;
      background: var(--bg-color); display:flex; flex-direction:column;
      justify-content:center; align-items:center; z-index:1000;
      text-align:center;
    }
    #openCardOverlay h1 { 
      font-size: 4em; margin-bottom:10px; 
      font-family: 'Dancing Script', cursive; 
      color: var(--primary-color);
    }
    #openCardOverlay p {
      font-family: 'Playfair Display', serif;
      font-style: italic;
      font-size: 1.2em;
      margin-bottom: 30px;
      color: #666;
    }
    .btn-elegant {
      padding: 15px 40px; font-size: 14px; border: none; border-radius: 50px;
      background: var(--primary-color); color: white; cursor: pointer;
      font-family: 'Montserrat', sans-serif; text-transform: uppercase;
      letter-spacing: 2px; font-weight: 500; transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(156, 130, 98, 0.3);
    }
    .btn-elegant:hover {
      background: var(--primary-dark); transform: translateY(-2px);
    }

    /* Sau khi mở thiệp */
    .hidden { display:none !important; }

    /* --- Hero Section --- */
    .hero {
      height: 100vh; 
      /* Ảnh bìa mẫu chất lượng cao */
      background: linear-gradient(rgba(0,0,0,0.4), rgba(0,0,0,0.4)), 
                  url('https://images.unsplash.com/photo-1583939003579-730e3918a45a?auto=format&fit=crop&w=1920&q=80') no-repeat center/cover;
      display:flex; flex-direction:column; justify-content:center; align-items:center;
      text-align:center; color:white;
    }
    .hero h1 { 
      font-size: 5em; font-family: 'Dancing Script', cursive; 
      margin-bottom: 10px; text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
    }
    .hero h2 { 
      font-size: 1.2em; font-weight: 300; font-family: 'Montserrat', sans-serif;
      text-transform: uppercase; letter-spacing: 5px; margin-bottom: 20px;
    }
    .hero p {
      font-size: 1.2em; font-family: 'Playfair Display', serif; font-style: italic;
      letter-spacing: 2px; border-top: 1px solid white; border-bottom: 1px solid white;
      padding: 10px 0;
    }

    /* --- Sections chung --- */
    section { padding: 80px 10%; }
    section h2 {
      font-size: 2.5em; margin-bottom: 30px;
      font-family: 'Playfair Display', serif; color: var(--primary-color);
      text-align: center; font-weight: 600;
    }
    .section-divider {
      width: 50px; height: 2px; background-color: var(--primary-color);
      margin: 0 auto 40px auto;
    }

    /* --- Countdown --- */
    .countdown { display:flex; justify-content:center; gap:20px; flex-wrap:wrap; }
    .countdown div { 
      background: white; color: var(--primary-color); padding: 20px 15px;
      border-radius: 8px; min-width: 90px; text-align: center;
      box-shadow: 0 4px 15px rgba(0,0,0,0.05); border: 1px solid #f0eae1;
    }
    .countdown span { 
      font-size: 2.2em; font-family: 'Playfair Display', serif; display:block; 
      margin-bottom: 5px;
    }

    /* --- Cô dâu, chú rể --- */
    .couple { display:flex; flex-wrap:wrap; justify-content:center; gap:40px; }
    .card { 
      background: white; padding: 40px 30px; border-radius: 12px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.03); width: 300px; text-align: center;
      border: 1px solid #f0eae1;
    }
    .card h3 { 
      margin-bottom: 15px; color: var(--primary-color); 
      font-family: 'Playfair Display', serif; font-size: 1.8em;
    }
    .card p { font-size: 0.95em; line-height: 1.8; color: #666; }

    /* --- Story --- */
    .story { 
      max-width: 700px; margin: auto; line-height: 2; 
      text-align: center; color: #555;
    }
    .story p { margin-bottom: 20px; }

    /* --- Location --- */
    .location { 
      background: white; padding: 40px; border-radius: 12px;
      max-width: 600px; margin: auto; text-align: center;
      box-shadow: 0 5px 20px rgba(0,0,0,0.03); border: 1px solid #f0eae1;
    }
    .location p { margin: 15px 0; font-size: 1.05em; line-height: 1.6; }
    .location strong { color: var(--primary-color); font-family: 'Playfair Display', serif; font-size: 1.1em; }
    .map-btn {
      display: inline-block; margin-top: 20px; padding: 12px 30px;
      background: white; color: var(--primary-color); text-decoration: none;
      border: 1px solid var(--primary-color); border-radius: 50px;
      text-transform: uppercase; font-size: 12px; letter-spacing: 1px;
      font-weight: 500; transition: 0.3s;
    }
    .map-btn:hover { background: var(--primary-color); color: white; }

    /* --- Gallery --- */
    .gallery {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 20px;
    }
    .gallery img {
      width: 100%; height: 250px; object-fit: cover; border-radius: 8px;
      cursor: pointer; transition: transform 0.3s ease;
      box-shadow: 0 4px 10px rgba(0,0,0,0.1);
    }
    .gallery img:hover { transform: scale(1.03); }

    /* Lightbox overlay */
    #lightboxOverlay {
      position:fixed; top:0; left:0; width:100%; height:100%;
      background:rgba(0,0,0,0.9); display:none; justify-content:center;
      align-items:center; z-index:1000;
    }
    #lightboxOverlay img { max-width:90%; max-height:85%; border-radius:8px; }

    /* --- RSVP Form --- */
    .rsvp-container {
      background: white; padding: 50px; border-radius: 12px;
      max-width: 600px; margin: auto; box-shadow: 0 10px 30px rgba(0,0,0,0.05);
    }
    .rsvp label { display: block; margin: 20px 0 8px; font-weight: 500; font-size: 0.9em; }
    .rsvp input, .rsvp select { 
      width: 100%; padding: 15px; border: 1px solid #ddd;
      border-radius: 8px; font-family: 'Montserrat', sans-serif;
      background: #fafafa; outline: none; transition: 0.3s;
    }
    .rsvp input:focus, .rsvp select:focus { border-color: var(--primary-color); background: white; }
    .rsvp button { width: 100%; margin-top: 30px; }

    /* --- Modal Quà mừng --- */
    .modal {
      position:fixed; top:0; left:0; width:100%; height:100%;
      background:rgba(0,0,0,0.7); display:none; justify-content:center;
      align-items:center; z-index:1000;
    }
    .modal-content {
      background:white; padding:40px; border-radius:12px; text-align:center;
      max-width:90%; width: 350px;
    }
    .modal-content h3 { font-family: 'Playfair Display', serif; color: var(--primary-color); font-size: 1.8em; margin-bottom: 20px; }
    .modal-content img { width:200px; height: 200px; margin:15px 0; border: 1px solid #ddd; padding: 5px; border-radius: 8px; }
    .modal-content p { line-height: 1.8; margin-bottom: 20px; color: #555; }

    /* --- Footer --- */
    .footer {
      background: var(--primary-color); color: white; text-align: center; padding: 60px 10%;
    }
    .footer h2 { color: white; font-family: 'Dancing Script', cursive; font-size: 3.5em; margin-bottom: 15px; }

    /* --- FAB Menu (Nổi góc) --- */
    .fab-menu {
      position:fixed; bottom:30px; right:30px; display:flex; flex-direction:column; gap:15px; z-index:500;
    }
    .fab {
      width:55px; height:55px; background:white; color:var(--primary-color); font-size:22px;
      border-radius:50%; display:flex; justify-content:center; align-items:center;
      cursor:pointer; box-shadow:0 4px 15px rgba(0,0,0,0.15);
      text-decoration:none; transition: 0.3s; border: 1px solid #f0eae1;
    }
    .fab:hover { background: var(--primary-color); color: white; transform: scale(1.1); }

    /* Hiệu ứng rung hộp quà */
    @keyframes shake {
      0%, 100% { transform: rotate(0deg); }
      25% { transform: rotate(15deg); }
      75% { transform: rotate(-15deg); }
    }
    #giftFab.shake { animation: shake 0.5s ease-in-out; }
    
  </style>
</head>
<body>

<div id="openCardOverlay">
  <h1>Hoàng Dũng & Quỳnh Linh</h1>
  <p>Trân trọng kính mời bạn đến tham dự ngày vui</p>
  <button id="openBtn" class="btn-elegant">MỞ THIỆP</button>
</div>

<div id="mainContent" class="hidden">

  <section class="hero">
    <h1>Hoàng Dũng ❤️ Quỳnh Linh</h1>
    <h2>We Are Getting Married</h2>
    <p>14 • 07 • 2026</p>
  </section>

  <section>
    <h2>Save The Date</h2>
    <div class="section-divider"></div>
    <div class="countdown">
      <div><span id="days">0</span>Ngày</div>
      <div><span id="hours">0</span>Giờ</div>
      <div><span id="minutes">0</span>Phút</div>
      <div><span id="seconds">0</span>Giây</div>
    </div>
  </section>

  <section style="background-color: white;">
    <h2>Cô Dâu & Chú Rể</h2>
    <div class="section-divider"></div>
    <div class="couple">
      <div class="card">
        <h3>🤵 Hoàng Dũng</h3>
        <p>Là người đàn ông chân thành, yêu thương và rất trách nhiệm trong mọi việc. Luôn đặt gia đình và Quỳnh Linh lên hàng đầu.</p>
      </div>
      <div class="card">
        <h3>👰 Quỳnh Linh</h3>
        <p>Là cô gái dịu dàng, hiểu chuyện và ấm áp. Quỳnh Linh luôn là nguồn động viên lớn nhất giúp Hoàng Dũng hoàn thiện bản thân.</p>
      </div>
    </div>
  </section>

  <section>
    <h2>Câu Chuyện Tình Yêu</h2>
    <div class="section-divider"></div>
    <div class="story">
      <p>Chúng tôi gặp nhau lần đầu trong một buổi tiệc bạn chung, từ ánh nhìn đầu tiên đã có cảm tình đặc biệt. Sau đó, hai đứa thường xuyên hẹn hò, cùng nhau trải qua những niềm vui, thử thách trong cuộc sống. Mỗi ngày bên nhau đều cảm thấy trân trọng và hạnh phúc.</p>
      <p>Giờ đây, chúng tôi quyết định viết tiếp câu chuyện ấy bằng chương mới lãng mạn nhất – hôn nhân. Hẹn gặp bạn trong ngày vui của chúng tôi!</p>
    </div>
  </section>

  <section style="background-color: white;">
    <h2>Sự Kiện Cưới</h2>
    <div class="section-divider"></div>
    <div class="location">
      <p><strong>Lễ Cưới Được Cử Hành Tại</strong></p>
      <p>Trung tâm Hội nghị Tiệc cưới ABC (Tầng 2 - Sảnh Ruby)</p>
      <p><strong>Thời gian:</strong> 10:00 Sáng | Thứ Ba, Ngày 14/07/2026</p>
      <p><strong>Địa chỉ:</strong> Số 123 Đường Tình Yêu, Quận Hạnh Phúc</p>
      <a href="https://maps.google.com" target="_blank" class="map-btn">Xem Bản Đồ</a>
    </div>
  </section>

  <section>
    <h2>Khoảnh Khắc Đáng Nhớ</h2>
    <div class="section-divider"></div>
    <div class="gallery">
      <img src="https://images.unsplash.com/photo-1511285560929-80b456fea0bc?auto=format&fit=crop&w=800&q=80" alt="Ảnh cưới 1">
      <img src="https://images.unsplash.com/photo-1519741497674-611481863552?auto=format&fit=crop&w=800&q=80" alt="Ảnh cưới 2">
      <img src="https://images.unsplash.com/photo-1606800052052-a08af7148866?auto=format&fit=crop&w=800&q=80" alt="Ảnh cưới 3">
      <img src="https://images.unsplash.com/photo-1520854221256-17451cc331bf?auto=format&fit=crop&w=800&q=80" alt="Ảnh cưới 4">
    </div>
    <p style="text-align:center; margin-top:20px; font-size: 0.9em; color: #888;">
      *Nhấp vào ảnh để xem kích thước lớn*
    </p>
  </section>

  <section id="rsvp" style="background-color: white;">
    <h2>Xác Nhận Tham Dự</h2>
    <div class="section-divider"></div>
    <div class="rsvp-container">
      <form class="rsvp" id="rsvpForm">
        <label for="name">Họ và tên của bạn:</label>
        <input type="text" id="name" placeholder="Nhập họ và tên đầy đủ..." required>
        
        <label for="phone">Số điện thoại:</label>
        <input type="tel" id="phone" placeholder="Nhập số điện thoại..." required>
        
        <label for="attend">Sự hiện diện của bạn:</label>
        <select id="attend">
          <option value="Có">Chắc chắn tôi sẽ tham dự</option>
          <option value="Không">Rất tiếc, tôi không thể đến được</option>
        </select>
        
        <label for="guests">Số người đi cùng (nếu có):</label>
        <input type="number" id="guests" placeholder="0" min="0" value="0">
        
        <button type="submit" class="btn-elegant">Gửi Xác Nhận</button>
      </form>
      <p id="thankYou" style="text-align:center; color:var(--primary-color); display:none; margin-top:20px; font-weight: 500;">
        ❤️ Cảm ơn bạn đã xác nhận! Hẹn gặp bạn tại lễ cưới nhé.
      </p>
    </div>
  </section>

  <section class="footer">
    <h2>Hoàng Dũng & Quỳnh Linh</h2>
    <p style="font-family: 'Playfair Display', serif; font-style: italic; font-size: 1.1em; opacity: 0.9;">
      Sự hiện diện của bạn là niềm vinh hạnh cho gia đình chúng tôi!
    </p>
  </section>
</div>

<div class="fab-menu">
  <div class="fab" id="btnMusic" title="Phát nhạc">🎵</div>
  <div class="fab" id="giftFab" title="Quà mừng">💌</div>
  <a href="#rsvp" class="fab" title="Gửi lời chúc">✏️</a>
</div>

<div id="lightboxOverlay"><img id="lightboxImg" src=""></div>

<div id="giftModal" class="modal">
  <div class="modal-content">
    <h3>Mừng Cưới</h3>
    <img src="https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=0123456789&color=9C8262" alt="QR Code Ngân Hàng">
    <p><strong>Ngân hàng:</strong> MB Bank<br><strong>Chủ TK:</strong> HOANG DUNG<br><strong>STK:</strong> 0123456789</p>
    <button id="copyBtn" class="btn-elegant" style="padding: 10px 25px;">Copy STK</button>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.5.1/dist/confetti.browser.min.js"></script>
<script>
  // Mở thiệp
  document.getElementById('openBtn').addEventListener('click', () => {
    document.getElementById('openCardOverlay').classList.add('hidden');
    document.getElementById('mainContent').classList.remove('hidden');
    // Có thể tự động bật nhạc tại đây nếu muốn (nhiều trình duyệt yêu cầu tương tác trước)
  });

  // Đếm ngược tới 14/07/2026
  const weddingDate = new Date("July 14, 2026 10:00:00").getTime();
  const c_days = document.getElementById('days'),
        c_hours = document.getElementById('hours'),
        c_minutes = document.getElementById('minutes'),
        c_seconds = document.getElementById('seconds');
        
  setInterval(() => {
    const now = new Date().getTime();
    const diff = weddingDate - now;
    if (diff > 0) {
      c_days.innerText = Math.floor(diff / (1000*60*60*24));
      c_hours.innerText = Math.floor((diff % (1000*60*60*24)) / (1000*60*60));
      c_minutes.innerText = Math.floor((diff % (1000*60*60)) / (1000*60));
      c_seconds.innerText = Math.floor((diff % (1000*60)) / 1000);
    }
  }, 1000);

  // Lightbox xem ảnh lớn
  const galleryImgs = document.querySelectorAll('.gallery img');
  const lightbox = document.getElementById('lightboxOverlay');
  const lightboxImg = document.getElementById('lightboxImg');
  
  galleryImgs.forEach(img => {
    img.addEventListener('click', () => {
      lightboxImg.src = img.src;
      lightbox.style.display = 'flex';
    });
  });
  lightbox.addEventListener('click', () => {
    lightbox.style.display = 'none';
  });

  // Chơi nhạc nền (Bạn cần thay 'link-nhac.mp3' bằng link nhạc thực tế)
  const audio = new Audio('https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3'); // Nhạc mẫu tạm thời
  audio.loop = true;
  let musicOn = false;
  
  document.getElementById('btnMusic').addEventListener('click', () => {
    if (!musicOn) { 
      audio.play(); 
      musicOn = true;
      document.getElementById('btnMusic').innerText = '⏸️';
    } else { 
      audio.pause(); 
      musicOn = false; 
      document.getElementById('btnMusic').innerText = '🎵';
    }
  });

  // Mở hộp quà
  const giftFab = document.getElementById('giftFab');
  const giftModal = document.getElementById('giftModal');
  
  giftFab.addEventListener('click', () => {
    giftFab.classList.add('shake');
    setTimeout(() => {
      giftFab.classList.remove('shake');
      giftModal.style.display = 'flex';
      // Bắn pháo giấy
      confetti({ particleCount: 150, spread: 80, origin: { y: 0.6 }, colors: ['#9C8262', '#ffffff', '#e8d5c4'] });
    }, 500);
  });
  
  // Đóng Modal hộp quà
  giftModal.addEventListener('click', (e) => {
    if (e.target === giftModal) {
      giftModal.style.display = 'none';
    }
  });
  
  // Copy STK ngân hàng
  document.getElementById('copyBtn').addEventListener('click', () => {
    const stk = '0123456789'; 
    navigator.clipboard.writeText(stk).then(() => {
      alert('Đã sao chép STK: ' + stk);
    });
  });

  // Xử lý RSVP
  const form = document.getElementById('rsvpForm');
  form.addEventListener('submit', (e) => {
    e.preventDefault();
    document.getElementById('thankYou').style.display = 'block';
    form.reset();
  });
</script>
</body>
</html>
